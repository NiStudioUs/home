{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Portfolio App (Chrome)",
            "request": "launch",
            "type": "dart",
            "cwd": "${workspaceFolder}/apps/portfolio",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "chrome"
            ],
            "preLaunchTask": "Run Data Migration"
        },
        {
            "name": "Portfolio App (Edge)",
            "request": "launch",
            "type": "dart",
            "cwd": "${workspaceFolder}/apps/portfolio",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "edge"
            ],
            "preLaunchTask": "Run Data Migration"
        },
        {
            "name": "Developer Profile (Chrome)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/apps/profile",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "Local:\\s+(https?://localhost:\\d+)",
                "uriFormat": "%s",
                "action": "debugWithChrome",
                "webRoot": "${workspaceFolder}/apps/profile"
            }
        },
        {
            "name": "Learning Hub (Chrome)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/apps/learning",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "Local:\\s+(https?://localhost:\\d+)",
                "uriFormat": "%s",
                "action": "debugWithChrome",
                "webRoot": "${workspaceFolder}/apps/learning"
            }
        }
    ],
    "compounds": [
        {
            "name": "Unified Launch (All Apps Chrome)",
            "configurations": [
                "Portfolio App (Chrome)",
                "Developer Profile (Chrome)",
                "Learning Hub (Chrome)"
            ]
        }
    ]
}